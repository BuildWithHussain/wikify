# Copy to .env and fill in. The app reads these on startup.
# Either name works: OPENROUTER_API_KEY or OPENROUTER_KEY.
OPENROUTER_API_KEY=

# Models (any OpenRouter model id). Override to switch.
# Keep JUDGE_MODEL different from VLM_MODEL (independent grader).
VLM_MODEL=mistralai/mistral-medium-3.1
JUDGE_MODEL=anthropic/claude-sonnet-4.6
CLASSIFIER_MODEL=google/gemini-2.5-flash
